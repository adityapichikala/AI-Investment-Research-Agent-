generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ResearchRun {
  id              String   @id @default(uuid())
  createdAt       DateTime @default(now())
  company         String
  verdict         Verdict
  investScore     Int
  confidenceScore Int
  finalReasoning  String
  keyStrengths    String[]
  keyRisks        String[]
  researchData    Json
  messages        Json
  tokensUsed      Int
}

enum Verdict {
  INVEST
  PASS
  NEUTRAL
}
